
a.internal-link[data-link-score$="x" ]::after{
    content: " |⭐ " 
}
a.internal-link[data-link-score$="xx"]::after{
    content: " |⭐️⭐️ " 
}
a.internal-link[data-link-score$="xxx"]::after{
    content: " |⭐️⭐️⭐️ " 
}
a.internal-link[data-link-score$="xxxx"]::after{
    content: " |⭐️⭐️⭐️⭐️ " 
}
a.internal-link[data-link-score$="xxxxx"]::after{
    content: " |⭐️⭐️⭐️⭐️⭐ " 
}



a.internal-link[data-link-fileClass$="#literature-note"]::before{
    content: "📔"
}
a.internal-link[data-link-fileClass$="#atomic-note"]::before{
    content: "⚛️"
}
a.internal-link[data-link-fileClass$="#evergreen-note"]::before{
    content: "🌲"
}
a.internal-link[data-link-fileClass$="#moc"]::before{
    content: "🗺️"
}


